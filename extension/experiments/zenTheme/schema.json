            "name": "colors",
            "type": "object",
            "properties": {
              "background": { "type": "string" },
              "foreground": { "type": "string" },
              "accent":     { "type": "string" }
            }
          }
        ]
      },
      {
        "name": "readColorsFile",
        "type": "function",
        "description": "Reads the omarchy zen-colors.json file and returns its mtime and content",
