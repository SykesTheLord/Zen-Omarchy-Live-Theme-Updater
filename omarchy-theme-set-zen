#!/bin/bash
# Applies the current omarchy theme colors to all Zen Browser profiles via userChrome.css.
# Requires Zen Browser to be restarted before changes are visible.

set -euo pipefail

COLORS_TOML="$HOME/.config/omarchy/current/theme/colors.toml"
ZEN_DIR="$HOME/.config/zen"

parse_hex() {
    grep -E "^${1}\s*=" "$COLORS_TOML" 2>/dev/null \
        | sed 's/.*"#\([0-9a-fA-F]\{6\}\)".*/\1/' \
        | head -1
}

if [[ ! -f "$COLORS_TOML" ]]; then
    echo "omarchy-theme-set-zen: colors.toml not found at $COLORS_TOML" >&2
    exit 1
fi

if [[ ! -d "$ZEN_DIR" ]]; then
    exit 0
fi

BG_HEX=$(parse_hex "background")
FG_HEX=$(parse_hex "foreground")
ACCENT_HEX=$(parse_hex "accent")

[[ -z "$BG_HEX" ]] && { echo "omarchy-theme-set-zen: could not parse background color" >&2; exit 1; }
[[ -z "$FG_HEX" ]]     && FG_HEX="e2e8f0"
[[ -z "$ACCENT_HEX" ]] && ACCENT_HEX="7c3aed"

PROFILES_INI="$ZEN_DIR/profiles.ini"
[[ -f "$PROFILES_INI" ]] || { echo "omarchy-theme-set-zen: no profiles.ini found" >&2; exit 0; }

THEME_NAME=$(cat "$HOME/.config/omarchy/current/theme.name" 2>/dev/null || echo "unknown")

while IFS= read -r profile_path; do
    PROFILE_DIR="$ZEN_DIR/$profile_path"
    [[ -d "$PROFILE_DIR" ]] || continue

    CHROME_DIR="$PROFILE_DIR/chrome"
    USER_JS="$PROFILE_DIR/user.js"
    echo "Chrome dir: $CHROME_DIR"
    echo "Profile dir: $PROFILE_DIR"
    mkdir -p "$CHROME_DIR"

    # Enable userChrome.css if not already
    if [[ ! -f "$USER_JS" ]] || ! grep -q "legacyUserProfileCustomizations" "$USER_JS"; then
        echo 'user_pref("toolkit.legacyUserProfileCustomizations.stylesheets", true);' >> "$USER_JS"
    fi

    cat > "$CHROME_DIR/userChrome.css" << EOF
/* Generated by omarchy-theme-set-zen — do not edit manually */
/* Theme: ${THEME_NAME} */

/* Zen sets --zen-main-browser-background as an inline style on these specific
   elements (not on :root), so we must target them directly. An !important
   stylesheet rule beats a non-important inline style on the same element. */
#zen-browser-background {
  --zen-main-browser-background: #${BG_HEX} !important;
}

#zen-toolbar-background {
  --zen-main-browser-background-toolbar: #${BG_HEX} !important;
}

/* These are set on :root by Zen's JS, so :root !important overrides them. */
:root {
  --zen-primary-color:  #${ACCENT_HEX} !important;
  --toolbox-textcolor:  #${FG_HEX} !important;
}
EOF
    echo "omarchy-theme-set-zen: updated $(basename "$profile_path") → $CHROME_DIR/userChrome.css"
done < <(grep "^Path=" "$PROFILES_INI" | cut -d= -f2-)

# Write JSON for the live-theme extension (profile path + /tmp for the Firefox add-on)
ZEN_COLORS_JSON="$HOME/.config/omarchy/current/theme/zen-colors.json"
TMP_COLORS_JSON="/tmp/omarchy-zen-colors.json"
cat > "$ZEN_COLORS_JSON" << EOF
{
  "background": "${BG_HEX}",
  "foreground": "${FG_HEX}",
  "accent": "${ACCENT_HEX}",
  "theme": "${THEME_NAME}"
}
EOF
cp "$ZEN_COLORS_JSON" "$TMP_COLORS_JSON"
echo "omarchy-theme-set-zen: wrote $ZEN_COLORS_JSON and $TMP_COLORS_JSON"

echo "omarchy-theme-set-zen: restart Zen Browser to apply"
